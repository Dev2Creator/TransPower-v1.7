{
  "name": "transpwr",
  "version": "1.7.0",
  "description": "Trans Power Sweetheart Assistant",
  "main": "main.js",
  "bin": {
    "transpwr": "./cli.js"
  },
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "author": {
    "name": "Anika Mukherjee",
    "email": "cuteypieanika@gmail.com"
  },
  "homepage": "https://transpower.app",
  "license": "AGPL-3.0",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.transpower.desktop",
    "productName": "Trans Power",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "www/assets/mascot.png"
    },
    "linux": {
      "target": [
        "deb",
        "tar.gz",
        "pacman"
      ],
      "icon": "www/assets/mascot.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "www/assets/mascot.png"
    }
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  }
}
